---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const mapaPages = await getCollection('pages', ({ data }) => data.type === 'mapa');
---

<Layout
  title="Most Pomocy - Strona główna"
  description="Mapa i strony pomocy Most Pomocy."
>
  <h1>Mapa wsparcia</h1>
  <p>Wybierz obszar pomocy:</p>
  <ul class="tiles">
    {mapaPages.map((page) => (
      <li>
        <a href={`/mapa/${page.slug}`}>{page.data.title}</a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .tiles {
    display: grid;
    gap: 0.75rem;
    padding-left: 0;
    list-style: none;
  }

  .tiles a {
    display: block;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: #111827;
    background: #fff;
  }
</style>
