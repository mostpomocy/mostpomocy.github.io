---
layout: null
---
[{% for post in site.posts %}{"id":{{ post.url | jsonify }},"title":{{ post.title | jsonify }},"url":{{ post.url | jsonify }},"category":{{ post.category | jsonify }},"tags":{{ post.tags | jsonify }},"excerpt":{{ post.excerpt | strip_html | strip_newlines | truncate: 200 | jsonify }},"content":{{ post.content | strip_html | normalize_whitespace | truncate: 1000 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
